---
import "../styles/global.css";
import Header from "../components/CustomHeader.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const { title = "HEV Doku", description = "Willkommen zur HEV Dokumentation" } =
  Astro.props;
---

<!doctype html>
<html lang="de" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <Header />
    <main class="container-content main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
