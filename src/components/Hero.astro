---
import Button from "./Button.astro";
import { BookOpen, Video, Headphones, CircleCheckBig } from "lucide-astro";
---

<section class="hero-section">
  <div class="container-content hero-container">
    <div class="circle circle-1"></div>
    <div class="circle circle-2"></div>

    <div class="hero-content">
      <div class="hero-left">
        <div class="hero-text">
          <h1 class="hero-title">
            <b class="highlight">METASFRESH</b><br /> einfach erklärt
          </h1>

          <p class="hero-description">
            Ihre zentrale Anlaufstelle für die Nutzung des metasfresh
            Mitgliederverwaltungssystems. Hier finden Sie verständliche
            Anleitungen, hilfreiche Tipps und weiterführende Informationen – von
            den Grundlagen bis zu fortgeschrittenen Funktionen.
          </p>
        </div>
        <div class="hero-button">
          <Button label="Kontakt" href="/kontakt" />
        </div>

        <ul class="feature-list">
          <li class="feature-item">
            <CircleCheckBig class="checkmark" size={20} />
            <span>Einfach zu bedienen</span>
          </li>
          <li class="feature-item">
            <CircleCheckBig class="checkmark" size={20} />
            <span>Video-Tutorials</span>
          </li>
          <li class="feature-item">
            <CircleCheckBig class="checkmark" size={20} />
            <span>Umfassende Dokumentation</span>
          </li>
          <li class="feature-item">
            <CircleCheckBig class="checkmark" size={20} />
            <span>täglicher Support</span>
          </li>
        </ul>
      </div>

      <div class="hero-right">
        <a href="/anleitungen" class="card card-primary">
          <BookOpen class="card-icon" size={40} />
          <div class="card-content">
            <h3>Anleitungen</h3>
            <p>Alle Anleitungen auf einen Blick.</p>
          </div>
        </a>

        <a href="/videos" class="card card-secondary">
          <Video class="card-icon" size={40} />
          <div class="card-content">
            <h3>Support</h3>
            <p>Wir helfen gerne weiter.</p>
          </div>
        </a>

        <a href="/support" class="card card-tertiary card-wide">
          <Headphones class="card-icon" size={40} />
          <div class="card-content">
            <h3>Neuer metasfresh Nutzer anfragen</h3>
            <p>Laden die sich das Formular herunter.</p>
          </div>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    width: 100%;
    background: var(--white);
  }

  .hero-container {
    position: relative;
    padding-top: var(--spacing-xxl);
    padding-bottom: var(--spacing-xxl);
    overflow: visible;
  }

  .circle {
    position: absolute;
    border-radius: 50%;
    background: var(--light-green);
    z-index: 0;
    pointer-events: none;
  }

  .circle-1 {
    width: 80px;
    height: 80px;
    top: 70px;
    right: 24px;
    opacity: 0.5;
  }

  .circle-2 {
    width: 100px;
    height: 100px;
    bottom: 8%;
    left: 48%;
    opacity: 0.4;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xxl);
    align-items: start;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxxs);
  }

  .hero-title {
    margin: 0;
  }

  .hero-title .highlight {
    color: var(--green);
  }

  .hero-description {
    color: var(--black);
    margin: 0;
  }

  .hero-button {
    margin-top: var(--spacing-xxxs);
  }

  .feature-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xxs) var(--spacing-sm);
    list-style: none;
    padding: 0;
    margin: var(--spacing-xxs) 0 0 0;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-xxs);
  }

  .checkmark {
    color: var(--green);
    flex-shrink: 0;
  }

  .hero-right {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 180px auto;
    gap: var(--spacing-xs);
    padding-top: var(--spacing-md);
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxs);
    padding: var(--spacing-sm);
    border-radius: 16px;
    text-decoration: none;
    box-shadow:
      0 20px 25px -5px rgba(0, 0, 0, 0.1),
      0 8px 10px -6px rgba(0, 0, 0, 0.1);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    text-decoration: none;
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxxs);
  }

  .card h3 {
    margin: 0;
  }

  .card p {
    margin: 0;
    opacity: 0.9;
  }

  .card-primary {
    background: var(--green);
    color: var(--white);
    grid-column: 1;
    grid-row: 1;
    align-self: stretch;
    justify-content: center;
  }

  .card-primary .card-icon {
    color: var(--white);
  }

  .card-secondary {
    background: var(--light-green);
    color: var(--black);
    grid-column: 2;
    grid-row: 1;
    align-self: end;
  }

  .card-secondary .card-icon {
    color: var(--black);
  }

  .card-wide {
    grid-column: 1 / -1;
    grid-row: 2;
  }

  .card-tertiary {
    background: var(--grey);
    color: var(--black);
  }

  .card-tertiary .card-icon {
    color: var(--black);
  }

  @media (max-width: 1024px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }
  }

  @media (max-width: 640px) {
    .hero-container {
      padding-top: var(--spacing-lg);
      padding-bottom: var(--spacing-lg);
    }

    .feature-list {
      grid-template-columns: 1fr;
    }

    .hero-right {
      grid-template-columns: 1fr;
    }

    .circle {
      display: none;
    }
  }
</style>
