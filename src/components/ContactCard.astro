---
import { Mail, Phone } from "lucide-astro";

export interface Props {
  emailAddress: string;
  phoneNumber: string;
}

const { emailAddress, phoneNumber } = Astro.props;

const contacts = [
  {
    icon: Mail,
    title: "E-Mail Support",
    description: "Antwort in der Regel innerhalb von 1–2 Werktagen",
    href: `mailto:${emailAddress}`,
    label: emailAddress,
  },
  {
    icon: Phone,
    title: "Telefon Support",
    description: "Mo–Fr, 08:00–17:00 Uhr",
    href: `tel:${phoneNumber.replace(/\s/g, "")}`,
    label: phoneNumber,
  },
];
---

<section class="contact-cards container-small text-link">
  {
    contacts.map(({ icon: Icon, title, description, href, label }) => (
      <div class="contact-card card-hover">
        <div class="contact-icon">
          <Icon size={20} />
        </div>
        <div class="contact-content">
          <h3>{title}</h3>
          <p>{description}</p>
          <a href={href}>{label}</a>
        </div>
      </div>
    ))
  }
</section>

<style>
  .contact-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-xs);
    padding-bottom: var(--spacing-xl);
    padding-top: var(--spacing-xl);
  }

  .contact-card {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm);
    background: var(--grey);
    border-left: 4px solid var(--green);
    border-radius: var(--spacing-xs);
  }

  .contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    min-width: 44px;
    background: var(--green);
    border-radius: 50%;
    color: var(--white);
  }

  .contact-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxxs);
  }

  .contact-content h3,
  .contact-content p {
    margin: 0;
  }

  @media (max-width: 600px) {
    .contact-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
