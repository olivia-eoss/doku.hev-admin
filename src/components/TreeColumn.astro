---
export interface ProcessItem {
  number: string;
  title: string;
  description: string;
  href?: string;
}

export interface Props {
  title?: string;
  description?: string;
  items: ProcessItem[];
}

const { title, description, items = [] } = Astro.props;
---

<section class="container-content process-section">
  <div class="process-container">
    <div class="process-header">
      <h2>{title}</h2>
      <p>{description}</p>
    </div>

    <div class="process-grid">
      {
        items.map((item) => (
          <a href={item.href ?? "#"} class="process-card">
            <span class="process-number">{item.number}</span>
            <h3 class="process-title">{item.title}</h3>
            <p class="process-text">{item.description}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .process-section {
    width: 100%;
    background: var(--white);
  }

  .process-container {
    padding-top: var(--spacing-xxl);
    padding-bottom: var(--spacing-xxl);
  }

  .process-header {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }

  .process-header h2 {
    margin: 0 0 var(--spacing-xxs) 0;
  }

  .process-header p {
    color: var(--black);
    opacity: 0.7;
    margin: 0 auto;
    line-height: 1.5;
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-xs);
  }

  .process-card {
    display: flex;
    flex-direction: column;
    padding: var(--spacing-sm);
    background: var(--green);
    border-radius: 16px;
    text-decoration: none;
    box-shadow:
      0 20px 25px -5px rgba(0, 0, 0, 0.08),
      0 8px 10px -6px rgba(0, 0, 0, 0.08);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .process-card:hover {
    transform: translateY(-3px);
    box-shadow:
      0 24px 30px -5px rgba(0, 0, 0, 0.13),
      0 10px 14px -6px rgba(0, 0, 0, 0.1);
    text-decoration: none;
  }

  .process-number {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: var(--white);
    opacity: 0.7;
    margin-bottom: var(--spacing-xs);
    letter-spacing: 0.05em;
  }

  .process-title {
    margin: 0 0 var(--spacing-xxs) 0;
    font-size: var(--font-size-h3);
    color: var(--white);
  }

  .process-text {
    margin: 0;
    font-size: 14px;
    color: var(--white);
    opacity: 0.85;
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .process-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .process-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
