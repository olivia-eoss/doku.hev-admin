---
import { getCollection } from "astro:content";

const docs = await getCollection("docs");

const navItems = docs
  .filter((entry) => entry.id.split("/").length === 1)
  .filter((entry) => entry.id !== "index")
  .map((entry) => ({
    href: `/${entry.id}`,
    label: entry.data.title,
  }));
---

<nav class="nav" id="mainNav">
  {
    navItems.map(({ href, label }) => (
      <a href={href} class="nav__link">
        <span>{label}</span>
      </a>
    ))
  }
</nav>

<style>
  .nav {
    display: flex;
    gap: var(--spacing-xxs);
    margin-inline: auto;
  }

  .nav__link {
    display: flex;
    align-items: center;
    font-family: var(--font-body);
    font-size: var(--font-size-body);
    color: var(--black);
    text-decoration: none;
    border-radius: 8px;
    background: color-mix(in srgb, var(--light-green) 30%, transparent);
    height: 40px;
    padding-inline: var(--spacing-md);
    transition: background 200ms ease;
    white-space: nowrap;
    gap: var(--spacing-xxs);
  }

  .nav__link:hover {
    background: color-mix(in srgb, var(--light-green) 60%, transparent);
  }

  @media (max-width: 1280px) {
    .nav {
      gap: var(--spacing-xxxs);
    }
    .nav__link {
      padding-inline: var(--spacing-xs);
    }
  }

  @media (max-width: 768px) {
    .nav {
      display: none;
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      background: var(--white);
      border-bottom: 1px solid var(--grey);
      flex-direction: column;
      padding: var(--spacing-xs) var(--spacing-md);
      gap: var(--spacing-xxs);
      z-index: 99;
      margin-inline: 0;
    }
    .nav.is-open {
      display: flex;
    }
    .nav__link {
      padding-inline: var(--spacing-md);
    }
  }
</style>
