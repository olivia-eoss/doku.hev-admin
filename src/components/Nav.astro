---
import { getCollection } from "astro:content";
import { getFirstDocHref } from "../utils/getFirstDocHref";

const docs = await getCollection("docs");

const navItems = await Promise.all(
  docs
    .filter((entry) => entry.id.split("/").length === 1)
    .filter((entry) => entry.id !== "index")
    .map(async (entry) => ({
      href: await getFirstDocHref(entry.id),
      label: entry.data.title,
    })),
);
---

<nav class="nav" id="mainNav">
  {
    navItems.map(({ href, label }) => (
      <a href={href} class="nav__link">
        <span>{label}</span>
      </a>
    ))
  }
</nav>

<style>
  .nav {
    display: flex;
    gap: clamp(4px, 1vw, var(--spacing-xxs));
    margin-inline: auto;
    flex: 1;
    justify-content: center;
  }

  .nav__link {
    display: flex;
    align-items: center;
    font-family: var(--font-body);
    font-size: var(--font-size-body);
    color: var(--black);
    text-decoration: none;
    border-radius: var(--spacing-xxs);
    background: color-mix(in srgb, var(--light-green) 30%, transparent);
    height: var(--spacing-lg);
    padding-inline: var(--spacing-md);
    transition: background 200ms ease;
    white-space: nowrap;
    gap: var(--spacing-xxs);
  }

  .nav__link:hover {
    background: color-mix(in srgb, var(--light-green) 60%, transparent);
  }

  @media (max-width: 1480px) {
    .nav {
      gap: var(--spacing-xxxs);
    }
    .nav__link {
      padding-inline: var(--spacing-xs);
    }
  }

  @media (max-width: 1200px) {
    .nav__link {
      background: transparent;
    }
    .nav__link:hover {
      background: color-mix(in srgb, var(--light-green) 30%, transparent);
    }
  }

  @media (max-width: 1000px) {
    .nav {
      display: none;
      position: absolute;
      top: var(--spacing-xxl);
      left: 0;
      right: 0;
      background: var(--white);
      border-bottom: 1px solid var(--grey);
      flex-direction: column;
      padding: var(--spacing-xs) var(--spacing-md);
      gap: var(--spacing-xxs);
      z-index: 99;
      margin-inline: 0;
    }
    .nav.is-open {
      display: flex;
    }
    .nav__link {
      padding-inline: var(--spacing-md);
      background: color-mix(in srgb, var(--light-green) 30%, transparent);
    }
  }
</style>
