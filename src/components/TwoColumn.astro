---
import { Mail, Phone } from "lucide-astro";

export interface Props {
  emailAddress: string;
  phoneNumber: string;
}

const { emailAddress, phoneNumber } = Astro.props;
---

<section class="contact-cards container-small">
  <div class="contact-card">
    <div class="contact-icon">
      <Mail size={20} />
    </div>
    <div class="contact-content">
      <h3>E-Mail Support</h3>
      <p>Antwort in der Regel innerhalb von 1–2 Werktagen</p>
      <a href={`mailto:${emailAddress}`}>{emailAddress}</a>
    </div>
  </div>

  <div class="contact-card">
    <div class="contact-icon">
      <Phone size={20} />
    </div>
    <div class="contact-content">
      <h3>Telefon Support</h3>
      <p>Mo–Fr, 08:00–17:00 Uhr</p>
      <a href={`tel:${phoneNumber.replace(/\s/g, "")}`}>{phoneNumber}</a>
    </div>
  </div>
</section>

<style>
  .contact-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-xs);
  }

  .contact-card {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm);
    background: var(--grey);
    border-left: 4px solid var(--green);
    border-radius: 12px;
  }

  .contact-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    min-width: 44px;
    background: var(--green);
    border-radius: 50%;
    color: var(--white);
  }

  .contact-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxxs);
  }

  .contact-content h3,
  .contact-content p {
    margin: 0;
  }

  .contact-content a {
    color: var(--green);
    text-decoration: none;
  }

  .contact-content a:hover {
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .contact-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
