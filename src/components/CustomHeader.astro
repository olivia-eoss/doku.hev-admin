---
import Logo from "../assets/Logo.svg";
import LogoDark from "../assets/Logo-dark.svg";
import Search from "@astrojs/starlight/components/Search.astro";
import Button from "../components/Button.astro";
import Nav from "./Nav.astro";
import { Menu, Sun, Moon } from "lucide-astro";
---

<header class="header sl-header">
  <div class="container-full header__inner">
    <a href="/" class="header__logo">
      <span class="logo-light"><Logo /></span>
      <span class="logo-dark"><LogoDark /></span>
    </a>
    <Nav />
    <div class="sl-search">
      <Search />
    </div>

    <div class="header__cta-wrap">
      <Button label="Kontakt" href="/kontakt" />
    </div>

    <button class="header__menu-btn" id="menuBtn" type="button">
      <Menu size={24} />
    </button>
    <button
      class="theme-toggle"
      id="themeToggle"
      type="button"
      aria-label="Theme wechseln"
    >
      <Sun size={20} id="iconSun" />
      <Moon size={20} id="iconMoon" />
    </button>
  </div>
</header>
<script>
  import { THEME_KEY } from "../utils/themeKey.ts";

  const toggle = document.getElementById("themeToggle");
  const sun = document.getElementById("iconSun");
  const moon = document.getElementById("iconMoon");

  function getTheme() {
    return (
      localStorage.getItem(THEME_KEY) ||
      (window.matchMedia("(prefers-color-scheme: dark)").matches
        ? "dark"
        : "light")
    );
  }

  function applyTheme(theme: string) {
    document.documentElement.dataset.theme = theme;
    localStorage.setItem(THEME_KEY, theme);
    if (sun && moon) {
      sun.style.display = theme === "dark" ? "none" : "block";
      moon.style.display = theme === "dark" ? "block" : "none";
    }
  }

  applyTheme(getTheme());

  toggle?.addEventListener("click", () => {
    const current = document.documentElement.dataset.theme;
    applyTheme(current === "dark" ? "light" : "dark");
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 10000;
    width: 100%;
    height: var(--spacing-xxl);
    background: var(--white);
  }

  .header__inner {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    height: 100%;
  }

  .header__logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  .header__menu-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--black);
    flex-shrink: 0;
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--black);
    padding: var(--spacing-xxxs);
    border-radius: 6px;
    flex-shrink: 0;
  }

  .theme-toggle:hover {
    background: var(--grey);
  }

  .logo-dark {
    display: none;
  }

  :global([data-theme="dark"]) .logo-light {
    display: none;
  }
  :global([data-theme="dark"]) .logo-dark {
    display: block;
  }

  @media (max-width: 1140px) {
    .header__cta-wrap {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .header__menu-btn {
      display: flex;
      margin-left: auto;
    }

    :global(.sl-search-input) {
      display: none;
    }

    :global(.sl-search) {
      min-width: unset;
      width: auto;
    }
  }
</style>
