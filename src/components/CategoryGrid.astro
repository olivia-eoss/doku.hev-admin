---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Unsere Anleitungen",
  description = "Wählen Sie eine Kategorie aus, um detaillierte Anleitungen und Hilfestellungen zu erhalten.",
} = Astro.props;
---

<section class="category-section">
  <div class="container-content category-container">
    <div class="category-header">
      <h2>{title}</h2>
      <p>{description}</p>
    </div>

    <div class="category-grid">
      <slot />
    </div>
  </div>
</section>

<style>
  .category-section {
    width: 100%;
    background: var(--white);
  }

  .category-container {
    padding-top: var(--spacing-xxl);
    padding-bottom: var(--spacing-xxl);
  }

  .category-header {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }

  .category-header h2 {
    margin: 0 0 var(--spacing-xxs) 0;
  }

  .category-header p {
    color: var(--black);
    opacity: 0.7;
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.5;
  }

  .category-grid {
    display: grid;
    grid-template-columns: 480px 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: var(--spacing-xs);
    height: 480px;
  }

  .category-grid > :global(:nth-child(1)) {
    grid-column: 1;
    grid-row: 1 / 3;
  }

  .category-grid > :global(:nth-child(2)) {
    grid-column: 2;
    grid-row: 1;
  }

  .category-grid > :global(:nth-child(3)) {
    grid-column: 3;
    grid-row: 1;
  }

  .category-grid > :global(:nth-child(4)) {
    grid-column: 2 / 4;
    grid-row: 2;
  }

  @media (max-width: 900px) {
    .category-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
      height: auto;
    }

    .category-grid > :global(:nth-child(1)) {
      grid-column: 1 / 3;
      grid-row: auto;
      min-height: 220px;
    }

    .category-grid > :global(:nth-child(2)),
    .category-grid > :global(:nth-child(3)) {
      grid-column: auto;
      grid-row: auto;
      min-height: 180px;
    }

    .category-grid > :global(:nth-child(4)) {
      grid-column: 1 / 3;
      grid-row: auto;
      min-height: 140px;
    }
  }

  @media (max-width: 480px) {
    .category-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-xxs);
    }

    .category-grid > :global(:nth-child(1)),
    .category-grid > :global(:nth-child(2)),
    .category-grid > :global(:nth-child(3)),
    .category-grid > :global(:nth-child(4)) {
      grid-column: 1;
      grid-row: auto;
      min-height: 160px;
    }
  }
</style>
