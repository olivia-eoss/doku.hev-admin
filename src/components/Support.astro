---
import kontaktImg from "../assets/Kontakt.png";
import { Image } from "astro:assets";

export interface Props {
  title: string;
  description: string;
  buttonLabel: string;
  buttonHref: string;
}

const { title, description, buttonLabel, buttonHref } = Astro.props;
---

<div class="container-small support-container">
  <div class="support-image">
    <Image src={kontaktImg} alt="Support Team" />
  </div>

  <div class="support-content">
    <h2>{title}</h2>
    <p>{description}</p>
    <a href={buttonHref} class="support-btn">{buttonLabel}</a>
  </div>
</div>

<style>
  .support-container {
    display: flex;
    align-items: center;
    gap: var(--spacing-xxl);
    padding-top: var(--spacing-xl);
    padding-bottom: var(--spacing-xl);
  }

  .support-image {
    flex-shrink: 0;
    width: 450px;
  }

  .support-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  .support-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .support-content h2 {
    margin: 0;
    max-width: 420px;
  }

  .support-content p {
    margin: 0;
    opacity: 0.75;
    line-height: 1.6;
    max-width: 420px;
  }

  .support-btn {
    display: inline-flex;
    align-items: center;
    height: 44px;
    padding-inline: var(--spacing-md);
    background: var(--green);
    color: var(--white);
    border-radius: 8px;
    text-decoration: none;
    font-size: var(--font-size-body);
    font-weight: 600;
    width: fit-content;
    transition: background 200ms ease;
  }

  .support-btn:hover {
    background: color-mix(in srgb, var(--green) 85%, black);
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .support-container {
      flex-direction: column;
      text-align: center;
      gap: var(--spacing-md);
    }

    .support-image {
      width: 240px;
    }

    .support-content {
      align-items: center;
    }

    .support-content p {
      max-width: 100%;
    }
  }
</style>
