---
import CustomLayout from "../layouts/CustomLayout.astro";
import HeroText from "../components/HeroText.astro";
import FeatureList from "../components/FeatureList.astro";
import HeroCards from "../components/HeroCards.astro";
import CategoryGrid from "../components/CategoryGrid.astro";
import CategoryCard from "../components/CategoryCard.astro";
import TreeColumn from "../components/TreeColumn.astro";
import Support from "../components/Support.astro";
import DownloadSection from "../components/DownloadSection.astro";

import { getFirstDocHref } from "../utils/getFirstDocHref";

const mitgliederHref = await getFirstDocHref("mitglieder");
const zahlungenHref = await getFirstDocHref("zahlungen");
const rechnungHref = await getFirstDocHref("rechnungen");
const berichteHref = await getFirstDocHref("berichte");
---

<CustomLayout title="Startseite" description="Willkommen zur HEV Dokumentation">
  <section class="hero-section container-content">
    <div class="hero-layout">
      <div class="hero-left">
        <div class="hero-animate hero-animate-1">
          <HeroText
            highlight="METASFRESH"
            title="einfach erklärt"
            description="Ihre zentrale Anlaufstelle für die Nutzung des metasfresh Mitgliederverwaltungssystems. Hier finden Sie verständliche Anleitungen, hilfreiche Tipps und weiterführende Informationen – von den Grundlagen bis zu fortgeschrittenen Funktionen."
            buttonLabel="Zum metasfresh Login"
            buttonHref="https://hev.metasfresh.com/login"
            arrow
          />
        </div>

        <div class="hero-animate hero-animate-2">
          <FeatureList
            items={[
              "Einfach zu bedienen",
              "Video-Tutorials",
              "Umfassende Dokumentation",
              "Täglicher Support",
            ]}
          />
        </div>
      </div>

      <div class="hero-animate hero-animate-3">
        <HeroCards
          cards={[
            {
              title: "Anleitungen",
              description: "Alle Anleitungen auf einen Blick.",
              href: "/mitglieder/neuaufnahme/1-standard-neuaufnahmen/",
              icon: "book",
              variant: "primary",
            },
            {
              title: "Support",
              description: "Wir helfen gerne weiter.",
              href: "/kontakt",
              icon: "video",
              variant: "secondary",
            },
            {
              title: "Neuer metasfresh Nutzer anfragen",
              description: "Laden Sie sich das Formular herunter.",
              href: "/#download",
              icon: "headphones",
              variant: "tertiary",
              wide: true,
            },
          ]}
        />
      </div>
    </div>
  </section>

  <CategoryGrid
    title="Unsere Anleitungen in Bereiche Unterteilt"
    description="Wählen Sie eine Kategorie aus, um detaillierte Anleitungen und Hilfestellungen zu erhalten."
  >
    <CategoryCard
      href={mitgliederHref}
      iconName="Users"
      variant="green"
      size="normal"
      title="Mitglieder"
      description="Mitgliederdaten erfassen, bearbeiten und verwalten."
    />
    <CategoryCard
      href={zahlungenHref}
      iconName="DollarSign"
      variant="light-green"
      size="small"
      title="Zahlungen"
      description="Zahlungen verbuchen und ESR Importe"
    />
    <CategoryCard
      href={rechnungHref}
      iconName="CreditCard"
      variant="grey"
      size="small"
      title="Rechnung"
      description="Rechnungen erstellen, suchen und Mahnungen"
    />
    <CategoryCard
      href={berichteHref}
      iconName="BarChart3"
      variant="dark-green"
      size="wide"
      title="Berichte"
      description="Auswertungen erstellen und Daten exportieren"
      decorationIconName="BarChart3"
    />
  </CategoryGrid>
  <TreeColumn
    title="Meist genutzte Prozesse"
    description="Die wichtigsten Workflows für den Alltag."
    items={[
      {
        number: "01",
        title: "Neues Mitglied erfassen",
        description:
          "Erfassung eines neuen Mitglieds in metasfresh – von der Eingabe der Stammdaten bis zur erfolgreichen Speicherung.",
        href: "/mitglieder/neuaufnahme/8-standardwerte/",
      },
      {
        number: "02",
        title: "Adressänderung",
        description:
          "Aktualisierung bestehender Mitgliedsdaten, damit Adressänderungen korrekt im System übernommen werden.",
        href: "/mitglieder/mutationen/2-standrad-adressaenderung/",
      },
      {
        number: "03",
        title: "Einzelrechnung erstellen",
        description:
          "Eine neue Rechnung für ein Mitglied erstellen und im System verbuchen.",
        href: "/rechnungen/fakturierung/einzelfakturierung/",
      },
    ]}
  />
  <Support
    title="Brauchen Sie Unterstützung?"
    description="Unser Support-Team steht Ihnen täglich zur Verfügung, um Ihnen bei allen Anliegen rund um metasfresh zu helfen. Zögern Sie nicht, uns zu kontaktieren – wir sind hier, um sicherzustellen, dass Sie das Beste aus unserem Mitgliederverwaltungssystem herausholen können."
  />
  <DownloadSection
    id="download"
    title="Downloads"
    description="Um die Zugriffsberechtigung zu ändern oder neu zu erstellen müssen Sie das Formular ausfüllen und uns schicken."
    items={[
      {
        title: "metasfresh",
        description: "Antrag Zugriff HEV metasfresh",
        href: "/downloads/antrag-metasfresh.pdf",
        type: "PDF",
      },
      {
        title: "Typo 3",
        description: "Antrag Zugriff Backend User Typo 3",
        href: "/downloads/antrag-typo3.pdf",
        type: "PDF",
      },
    ]}
  />
</CustomLayout>

<style>
  .hero-section {
    padding-block: var(--spacing-xl);
  }

  .hero-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xxl);
    align-items: start;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .hero-section {
    padding-block: var(--spacing-xl);
  }

  .hero-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xxl);
    align-items: start;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .hero-animate {
    opacity: 0;
    transform: translateY(28px);
    will-change: opacity, transform;
  }

  .hero-animate.is-visible {
    animation: heroFadeUp 0.8s ease-out forwards;
  }

  .hero-animate-1.is-visible {
    animation-delay: 0.05s;
  }

  .hero-animate-2.is-visible {
    animation-delay: 0.2s;
  }

  .hero-animate-3.is-visible {
    animation-delay: 0.35s;
  }

  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(28px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-animate {
      opacity: 1;
      transform: none;
    }

    .hero-animate.is-visible {
      animation: none;
    }
  }

  @media (max-width: 1024px) {
    .hero-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 1024px) {
    .hero-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
<script is:inline>
  const animatedItems = document.querySelectorAll(".hero-animate");

  const observer = new IntersectionObserver(
    (entries, observerInstance) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("is-visible");
          observerInstance.unobserve(entry.target);
        }
      });
    },
    {
      threshold: 0.3,
      rootMargin: "0px 0px -10% 0px",
    },
  );

  animatedItems.forEach((item) => observer.observe(item));
</script>
